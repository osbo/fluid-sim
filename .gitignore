# Unity generated
*.meta
Library/
Logs/
UserSettings/
MemoryCaptures/
Temp/
Obj/
Build/
Builds/

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.sln
*.unityproj
*.suo
*.user
*.userprefs

# OS
.DS_Store
Thumbs.db

# Videos and large recordings
*.mp4
*.mov
*.avi
*.mkv
Recordings/

# Crash logs
*.stackdump
mono_crash.*

# Python (scripts in Assets/Scripts)
__pycache__/
*.py[cod]
*.pyo
.Python
*.so

# Large Unity streaming test assets (regenerate locally)
Assets/StreamingAssets/TestData/

# Local datasets and training caches under Scripts (often >100MB; regenerate locally)
Assets/Scripts/data/

# PyTorch compile caches (torch.compile / Inductor / Triton; regenerate locally)
Assets/Scripts/.triton_cache/
Assets/Scripts/.torch_inductor_cache/

# Intermediate training checkpoints (large; regenerate with LeafOnly.py --track-training)
Assets/Scripts/weights/*_step*.bytes

# LaTeX build products (regenerate with latexmk)
Paper/paper.aux
Paper/paper.bbl
Paper/paper.blg
Paper/paper.fdb_latexmk
Paper/paper.fls
Paper/paper.log
Paper/paper.out
Paper/paper.synctex.gz
Paper/supplementary.aux
Paper/supplementary.log
Paper/supplementary.out
Paper/supplementary.synctex.gz
