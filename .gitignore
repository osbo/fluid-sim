# Unity generated
*.meta
Library/
Logs/
UserSettings/
MemoryCaptures/
Temp/
Obj/
Build/
Builds/

# Visual Studio / Rider
.vs/
.idea/
*.csproj
*.sln
*.unityproj
*.suo
*.user
*.userprefs

# OS
.DS_Store
Thumbs.db

# Videos and large recordings
*.mp4
*.mov
*.avi
*.mkv
Recordings/

# Crash logs
*.stackdump
mono_crash.*

# Python (scripts in Assets/Scripts)
__pycache__/
*.py[cod]
*.pyo
.Python
*.so

# Large Unity streaming test assets (regenerate locally). Track only explicit runs below.
Assets/StreamingAssets/TestData/**
!Assets/StreamingAssets/TestData/Run_2026-05-11_10-26-02/
!Assets/StreamingAssets/TestData/Run_2026-05-11_10-26-02/**

# Local datasets and training caches under Scripts (often >100MB; regenerate locally)
Assets/Scripts/data/

# PyTorch compile caches (torch.compile / Inductor / Triton; regenerate locally)
Assets/Scripts/.triton_cache/
Assets/Scripts/.torch_inductor_cache/

# Trained weights, checkpoints, exports (large; regenerate locally or store elsewhere)
Assets/Scripts/weights/
Assets/Scripts/leafonly_ablation_weights/
Assets/Scripts/*.bytes
Assets/Scripts/*.pt

# LaTeX build products (regenerate with latexmk)
Paper/paper.aux
Paper/paper.bbl
Paper/paper.blg
Paper/paper.fdb_latexmk
Paper/paper.fls
Paper/paper.log
Paper/paper.out
Paper/paper.pdf
Paper/paper.synctex.gz
Paper/supplementary.aux
Paper/supplementary.bbl
Paper/supplementary.blg
Paper/supplementary.fdb_latexmk
Paper/supplementary.fls
Paper/supplementary.log
Paper/supplementary.out
Paper/supplementary.pdf
Paper/supplementary.synctex.gz

# Large dev / asset blobs (not for version control; were removed from history)
Assets/Scripts/Octree
Assets/Scripts/inspect_model_plot.png
Assets/Meshes/bunny.obj
Assets/Meshes/stanford-bunny.obj
Assets/Shaders/*.exr

# Benchmark / profiler / Nsight (GitHub rejects >100 MB; warns >50 MB)
# — Nsight Compute exports and imports (any benchmark subfolder under results/)
Assets/Scripts/results/**/ncu/
# — torch.profiler Chrome trace (50–500+ MB); name is fixed in BenchmarkBaseline.py
Assets/Scripts/results/**/torch_profiler_trace.json
# — Nsight Systems / Nsight Graphics / other vendor trace blobs (any path)
*.ncu-rep
*.nsys-rep
*.qdrep
*.nvpayload
# — PyTorch / tooling trace JSON variants (often huge)
*.pt.trace.json
# — FreqRankByDistance disk cache (can grow with grid size)
Assets/Scripts/.freq_rank_cache.npz
# — LeafOnly training context shards (often multi-GB; regenerate locally)
**/.leafonly_training_context_cache/
